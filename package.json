{
    "name": "page-mcp-plugin",
    "version": "1.2.2",
    "private": true,
    "description": "Chrome extension — AI assistant that discovers page MCP tools",
    "type": "module",
    "scripts": {
        "dev": "sh -c 'vite build --watch & BUILD_TARGET=content vite build --watch & BUILD_TARGET=bridge vite build --watch & wait'",
        "build": "vite build && BUILD_TARGET=content vite build && BUILD_TARGET=bridge vite build",
        "typecheck": "tsc --noEmit",
        "test": "vitest run"
    },
    "dependencies": {
        "@page-mcp/core": "3.1.0",
        "@page-mcp/protocol": "3.1.0",
        "@page-mcp/webmcp-adapter": "3.1.0",
        "dompurify": "^3.3.2",
        "lucide-react": "^0.577.0",
        "marked": "^17.0.4",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "sval": "^0.6.8",
        "turndown": "^7.2.2"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.2.1",
        "@types/chrome": "^0.0.287",
        "@types/dompurify": "^3.2.0",
        "@types/marked": "^6.0.0",
        "@types/node": "^22.0.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@types/turndown": "^5.0.6",
        "@vitejs/plugin-react": "^5.1.4",
        "tailwindcss": "^4.2.1",
        "typescript": "^5.4.0",
        "vite": "^6.0.0",
        "vitest": "^3.2.4"
    },
    "pnpm": {
        "overrides": {
            "picomatch": "^4.0.4"
        }
    }
}
